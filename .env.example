# ============================================
# VARIÁVEIS DE AMBIENTE — ta-rodando
# ============================================
# 1. Copie este arquivo:       cp .env.example .env
# 2. Preencha os valores em .env
# 3. NUNCA commite .env (já está no .gitignore)
# 4. No Vercel, cadastrar TODAS no painel (Settings > Environment Variables)
# ============================================

# --- Claude / Anthropic (uso do Claude Code durante o dev) ---
# Chave do envelope do bootcamp. Limite individual de US$ 20.
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (dedup de alertas) ---
# Project Settings > API no dashboard do Supabase
SUPABASE_URL=https://<seu-projeto>.supabase.co
# Service role — backend only, NUNCA expor no frontend
SUPABASE_SERVICE_ROLE_KEY=

# --- N8N self-hosted (Atlas) ---
N8N_BASE_URL=https://n8n.moonventures-atlas.com.br
N8N_API_KEY=

# --- GitHub Webhook ---
# String aleatória — a MESMA precisa ser configurada nas settings do webhook no GitHub
GITHUB_WEBHOOK_SECRET=

# --- Evolution API (envio de WhatsApp) ---
EVOLUTION_API_URL=http://<host>:<port>
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Número/grupo WhatsApp destino. Formatos aceitos pela Evolution:
#   individual:  5511999999999@s.whatsapp.net
#   grupo:       <group-id>@g.us
WHATSAPP_TARGET=

# --- Cron endpoint protection ---
# String aleatória. Enviada como Bearer pelo Vercel Cron no header Authorization.
CRON_SECRET=
